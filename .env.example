# Database Configuration
DB_PATH=./data

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Backend Services (for production integration)
FASTAPI_BACKEND_URL=http://localhost:8000
FASTAPI_API_KEY=your_api_key_here

# LLM Configuration
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key
FAL_API_KEY=your_fal_key

# Email Configuration (for reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Storage Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=52428800

# Authentication
JWT_SECRET=your_jwt_secret_key_change_in_production
SESSION_SECRET=your_session_secret_key_change_in_production

# Feature Flags
ENABLE_MOCK_AGENTS=true
ENABLE_REAL_PDF_PARSING=false
ENABLE_ANALYTICS=true

# Sentry Error Tracking (optional)
SENTRY_DSN=https://your_sentry_key@sentry.io/project_id

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
